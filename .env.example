# Environment Variables Example
# Copy this to .env.local for local development

NEXT_PUBLIC_SITE_URL=https://vettcodecli.vercel.app
NEXT_PUBLIC_GITHUB_REPO=https://github.com/mixifys33/vettcodecli

# OpenRouter API (Free tier available at https://openrouter.ai)
# Get your free API key at: https://openrouter.ai/keys
# Free models available: gemma-2-9b-it, llama-3-8b-instruct, mistral-7b-instruct
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Leave empty to use mock responses for demo
# OPENROUTER_API_KEY=
